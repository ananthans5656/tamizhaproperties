# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

use_modular_headers!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'TamizhaAdmin' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'TamizhaAdminTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    # Replace ReactCommon public modulemap with empty one to prevent redefinition errors in Xcode 26
    react_common_modulemap = "#{installer.sandbox.root}/Headers/Public/ReactCommon/ReactCommon.modulemap"
    if File.exist?(react_common_modulemap)
      File.write(react_common_modulemap, "// intentionally empty\n")
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['CLANG_WARN_STRICT_PROTOTYPES'] = 'NO'
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -w'
        config.build_settings['OTHER_CFLAGS'] = '$(inherited) -w'
        config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
        # Fix: Xcode 26 — ReactCommon and React-RuntimeApple both declare module ReactCommon
        if target.name == 'ReactCommon' || target.name == 'React-RuntimeApple'
          config.build_settings.delete('MODULEMAP_FILE')
        end
      end
    end
  end
end
